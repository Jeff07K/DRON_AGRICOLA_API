<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <Button
        android:id="@+id/btnConectar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:text="CONECTAR BLUETOOTH"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#0000FF"
        android:layout_margin="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAdelante"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ADELANTE A"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FF0000"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnReversa"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="REVERSA B"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#FF0000"
            android:layout_margin="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnIzquierda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="IZQUIERDA C"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#FF0000"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnDerecha"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DERECHA D"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#FF0000"
            android:layout_margin="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnFrenar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="FRENAR E"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FFA500"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnDisparo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DISPARO F"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#00FF00"
            android:layout_margin="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="(°w°)"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#111111" />

</LinearLayout>